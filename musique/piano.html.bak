                <li><a href="\musique\debussy\les-soirs-illuminés-par-l'ardeur-du-charbon.html">Debussy : Les soirs illuminés par l’ardeur du charbon</a></li>
                <li><a href="\musique\debussy\the-little-shepherd.html">Debussy : The Little Shepherd</a></li>
                <li><a href="/musique/brahms/sonata3.html">Brahms : Sonate pour piano en fa mineur, opus 5 (coda du V. <i>Finale</i>)</a></li>
            </ol>
